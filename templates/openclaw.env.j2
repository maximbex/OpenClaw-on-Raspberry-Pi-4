NODE_ENV=production

# --- The Cognitive Engines ---
OPENAI_API_KEY={{ vault_openai_api_key }}
ANTHROPIC_API_KEY={{ vault_anthropic_api_key }}
DISCORD_TOKEN={{ vault_discord_token | default('') }}

# --- The Kimi/Vivienne NFS Optimizations ---
# This fulfills the README promise, forcing the SQLite 
# scratchpad into the Pi's physical silicon.
SQLITE_JOURNAL_MODE=WAL
SQLITE_SYNCHRONOUS=NORMAL
SQLITE_TEMP_STORE=MEMORY
SQLITE_TMPDIR=/dev/shm/openclaw-tmp
